{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "off"
  },
  "ignorePatterns": ["**/dist/**", "ecosystem-tests/**", "deno/**"],
  "rules": {
    "no-unused-vars": [
      "error",
      {
        "args": "none",
        "caughtErrors": "none",
        "ignoreRestSiblings": true,
        "varsIgnorePattern": "^_",
        "fix": {
          "imports": "safe-fix",
          "variables": "off"
        }
      }
    ],
    "no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "regex": "^increase(/.*)?",
            "message": "Use a relative import, not a package import."
          }
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": ["tests/**","examples/**"],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ]
}
